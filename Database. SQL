CREATE TABLE crop_data (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    crop_name TEXT NOT NULL,
    rainfall INTEGER,
    temperature INTEGER,
    soil_fertility INTEGER,
    predicted_yield TEXT
);

