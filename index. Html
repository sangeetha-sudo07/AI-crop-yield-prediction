<!DOCTYPE html>
<html>
<head>
<title>AI Crop Yield Prediction</title>
</head>
<body>

<h1>AI Crop Yield Prediction</h1>

<input type="text" id="crop" placeholder="Crop Name"><br><br>

<input type="number" id="rainfall" placeholder="Rainfall"><br><br>

<button onclick="predict()">Predict Yield</button>

<h2 id="result"></h2>

<script>
function predict(){
 let rainfall =
 Number(document.getElementById("rainfall").value);

 if(rainfall > 1000){
   document.getElementById("result").innerHTML =
   "High Yield Expected";
 }
 else if(rainfall >= 700){
   document.getElementById("result").innerHTML =
   "Medium Yield Expected";
 }
 else{
   document.getElementById("result").innerHTML =
   "Low Yield Expected";
 }
}
</script>

</body>
</html>
